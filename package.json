{
  "name": "mockcloud",
  "version": "0.1.0",
  "description": "A lightweight local mock of AWS services for development and testing",
  "license": "MIT",
  "author": "Jon Holman",
  "repository": {
    "type": "git",
    "url": "https://github.com/stratiformdigital/MockCloud.git"
  },
  "homepage": "https://github.com/stratiformdigital/MockCloud",
  "bugs": {
    "url": "https://github.com/stratiformdigital/MockCloud/issues"
  },
  "keywords": [
    "aws",
    "mock",
    "local",
    "testing",
    "development",
    "s3",
    "lambda",
    "dynamodb",
    "cloudformation"
  ],
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "yarn@4.13.0",
  "scripts": {
    "dev": "tsx src/cli.ts",
    "serve": "tsx src/cli.ts serve",
    "test": "./scripts/test.sh",
    "test:e2e": "./scripts/run-with-server.sh yarn vitest run --config vitest.e2e.config.ts",
    "build:console": "cd console && yarn build",
    "dev:console": "cd console && yarn dev"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch-logs": "^3.1009.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.1009.0",
    "@aws-sdk/lib-dynamodb": "^3.1009.0",
    "commander": "^14.0.3",
    "dotenv": "^17.2.3",
    "jszip": "^3.10.1",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@aws-sdk/client-api-gateway": "^3.1009.0",
    "@aws-sdk/client-cloudformation": "^3.1009.0",
    "@aws-sdk/client-cloudwatch": "^3.1009.0",
    "@aws-sdk/client-cognito-identity": "^3.1009.0",
    "@aws-sdk/client-dynamodb": "^3.1009.0",
    "@aws-sdk/client-ec2": "^3.1009.0",
    "@aws-sdk/client-eventbridge": "^3.1009.0",
    "@aws-sdk/client-iam": "^3.1009.0",
    "@aws-sdk/client-kms": "^3.1009.0",
    "@aws-sdk/client-lambda": "^3.1009.0",
    "@aws-sdk/client-s3": "^3.1009.0",
    "@aws-sdk/client-secrets-manager": "^3.1009.0",
    "@aws-sdk/client-ssm": "^3.1009.0",
    "@aws-sdk/client-sts": "^3.1009.0",
    "@aws-sdk/client-wafv2": "^3.1009.0",
    "@types/node": "^25.5.0",
    "aws-cdk": "^2.243.0",
    "aws-cdk-lib": "^2.243.0",
    "constructs": "^10.5.1",
    "playwright": "^1.58.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
