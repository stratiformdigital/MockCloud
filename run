#!/bin/bash
set -eu -o pipefail
cd "$(dirname "$0")"

PORT=4444
LOG=data/mockcloud.log

is_running() {
  curl -s "http://localhost:$PORT/" -o /dev/null 2>/dev/null
}

cmd_start() {
  if is_running; then
    echo "MockCloud already running on port $PORT"
    exit 0
  fi

  echo "Starting MockCloud on port $PORT..."
  mkdir -p data
  nohup yarn tsx src/cli.ts serve > "$LOG" 2>&1 &

  elapsed=0
  last_line=""
  while [ $elapsed -lt 180000 ]; do
    sleep 0.5
    elapsed=$((elapsed + 500))
    if is_running; then
      echo "MockCloud ready (${elapsed}ms)"
      return
    fi
    if [ -f "$LOG" ]; then
      line=$(tail -1 "$LOG")
      if [ -n "$line" ] && [ "$line" != "$last_line" ]; then
        echo "  $line"
        last_line="$line"
      fi
    fi
  done

  echo "MockCloud failed to start within 180s. Check $LOG"
  exit 1
}

cmd_stop() {
  yarn tsx src/cli.ts stop
}

cmd_reset() {
  if is_running; then
    cmd_stop
    sleep 1
  fi
  rm -rf data/state data/s3 data/mockcloud.pid data/mockcloud.log
  echo "Data cleared."
}

case "${1:-start}" in
  start) cmd_start ;;
  stop)  cmd_stop ;;
  reset) cmd_reset ;;
  serve|clear|env) yarn tsx src/cli.ts "$@" ;;
  *)
    echo "Unknown command: $1"
    echo ""
    echo "Usage: ./run <command>"
    echo ""
    echo "  start   Start MockCloud server (default)"
    echo "  stop    Stop MockCloud server"
    echo "  reset   Clear all data and stop server"
    echo "  clear   Clear persisted state"
    echo "  serve   Start server in foreground"
    echo "  env     Print AWS environment variables"
    exit 1
    ;;
esac
